# Prisma AI — Backend environment
# Copy to backend/.env for local overrides (optional — defaults work for dev).

# =============================================================================
# REQUIRED IN PRODUCTION (Render)
# =============================================================================

# Comma-separated browser origins allowed to call the API (your Vercel URL(s))
# Example: https://your-app.vercel.app,https://www.your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# =============================================================================
# CORE
# =============================================================================

# Session lifetime in seconds (default: 2 hours). In-memory until Supabase phase.
SESSION_TTL_SECONDS=7200

# Maximum upload size in megabytes
MAX_UPLOAD_MB=25

# Sample datasets directory (Docker/Render: /sample-data)
# SAMPLES_DIR=/sample-data

# =============================================================================
# AI NARRATION (optional — analytics work without any LLM)
# =============================================================================

# Provider: none | ollama (more providers planned)
LLM_PROVIDER=none

# Legacy alias: set true to enable Ollama when LLM_PROVIDER=none
OLLAMA_ENABLED=false

# Only when LLM_PROVIDER=ollama (or OLLAMA_ENABLED=true):
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=30.0
OLLAMA_CONNECT_TIMEOUT=5.0

# =============================================================================
# SECURITY (optional)
# =============================================================================

# Enable in-memory upload rate limiting (single-instance demos only)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_UPLOADS_PER_MINUTE=10

# Render sets PORT automatically — do not set locally unless needed
# PORT=8000
