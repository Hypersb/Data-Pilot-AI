# Prisma AI — Backend environment (copy to .env for local overrides)

# Comma-separated allowed browser origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8501

# Session lifetime in seconds (default: 2 hours)
SESSION_TTL_SECONDS=7200

# Maximum upload size in megabytes
MAX_UPLOAD_MB=25

# Optional: override sample dataset directory (Docker uses /sample-data)
# SAMPLES_DIR=/sample-data

# Optional Ollama integration for LLM-enhanced chat and reports
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120.0
