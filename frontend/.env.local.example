# Prisma AI — Frontend environment (copy to .env.local for local development)
#
# Production (Vercel): set these in Project → Settings → Environment Variables.

# Required in production — your Render API URL (no trailing slash)
# Example: https://prisma-ai-api.onrender.com
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

# Canonical site URL for Open Graph / metadata (optional locally)
# Example: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
